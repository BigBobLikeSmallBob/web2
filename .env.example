# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:5000

# Authentication (JWT)
# Tạo chuỗi ngẫu nhiên bằng lệnh: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_here

# SQL Server Configuration
# Bạn có thể dùng chuỗi DATABASE_URL hoặc các biến rời
MSSQL_HOST=127.0.0.1

# CÁCH 1: Dùng Instance Name (Khuyên dùng cho Named Instance)
MSSQL_INSTANCE=MSSQLSERVER01
# MSSQL_PORT= (Để trống khi dùng Instance Name)

# CÁCH 2: Dùng Cổng tĩnh (Bỏ MSSQL_INSTANCE nếu dùng cổng này)
# MSSQL_PORT=1433 

MSSQL_USER=sa
MSSQL_PASSWORD=your_sql_server_password
MSSQL_DATABASE=tuyendung_db
# DATABASE_URL=mssql://sa:your_sql_server_password@localhost:1433/tuyendung_db


# Email Configuration (SMTP - Ví dụ dùng Gmail)
# Nếu dùng Gmail, mật khẩu phải là "App Password" (Mật khẩu ứng dụng)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="Đội ngũ Tuyển dụng <your_email@gmail.com>"

# Initial Admin Seed (Dùng cho lệnh npm run seed:admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123